                "suffix": "\n"
            },
            "photos": {
                "enabled": true,
                "separator": "\n\n",
                "prefix": "\n",
                "suffix": "\n"
            }
        },
        "custom": {
            "items": [
                "Today's Rating: \n"
            ],
            "separator": "\n",
            "prefix": "\n\n",
            "suffix": ""
        },
        "custom_placement": "before",
        "writing_lines": 3,
        "header_suffix": ": "
    },
    "day_crossover": {
        "time": {
            "hour": 0,
            "minute": 0,
            "second": 0
        },
        "move_direction": "disable"
    },
    "photos": {
        "enable_photo_transfer": false,
        "photo_locations": [],
        "type_conversion": {
            "enabled": false,
            "delete_pre_converted_files": true,
            "conversions": {}
        },
        "enable_google_photos_extraction": true
    },
    "earliest_entry": {
        "day": 0,
        "month": 0,
        "year": 0
    },
    "permissions": {
        "enable_writing_to_file": true,
        "enable_new_directory_and_file_creation": true
    },
    "console_output_level": "minimum"
