{
    "Confused?": "Read the README file. In fact, you should read that before touching any of this.",
    "journal_root": "path/to/a/directory",
    "journal_format": {
        "requires_programming": {
            "matching_entries": {
                "enabled": true,
                "separator": ", ",
                "preliminary_text": "\nPrevious Same-Date Journals: ",
                "ending_text": "\n"
            },
            "photos": {
                "enabled": true,
                "separator": "\n\n",
                "preliminary_text": "\n",
                "ending_text": "\n"
            }
        },
        "custom": {
            "items": [
                "Today's Rating: \n"
            ],
            "separator": "\n",
            "preliminary_text": "\n\n",
            "ending_text": ""
        },
        "custom_placement": "before",
        "writing_lines": 3
    },
    "day_crossover": {
        "time": {
            "hour": 0,
            "minute": 0,
            "second": 0
        },
        "move_direction": "disable"
    },
    "photos": {
        "enable_photo_transfer": false,
        "photo_locations": [
            "path/to/a/directory"
        ],
        "type_conversion": {
            "enabled": false,
            "delete_pre_converted_files": false,
            "conversions": {
                "jpg": "png"
            }
        },
        "google_photos_extraction_enabled": true
    },
    "other": {
        "earliest_journal": {
            "day": 0,
            "month": 0,
            "year": 0
        },
        "enable_writing_to_file": true,
        "enable_new_directory_and_file_creation": true
    }
}